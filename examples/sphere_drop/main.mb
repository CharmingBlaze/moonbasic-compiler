; 3D physics: click to drop colored spheres onto a platform; balls that fall off are removed.
; Orbit: hold RIGHT mouse and drag (same pattern as terrain_colored). Left click = spawn.
;
; Run from repo root (needs Jolt + CGO, fullruntime):
;   moonrun examples/sphere_drop/main.mb

CONST MAX_BALLS = 48
CONST BALL_R = 0.35
CONST SEGS = 18
; Platform: half-extents 6 x 0.2 x 6 (see BODY3D.ADDBOX) => 12 x 0.4 x 12 world units
CONST PLAT_HX = 6.0
CONST PLAT_HY = 0.4
CONST PLAT_HZ = 6.0
CONST EDGE_KILL = 7.8
CONST SPAWN_Y = 6.0
CONST ORBIT_BTN = 1
CONST LEFT_BTN = 0
CONST ORBIT_SENS = 0.0055
CONST PITCH_MIN = -0.12
CONST PITCH_MAX = 1.28
CONST ZOOM_WHEEL = 0.9
CONST DIST_MIN = 4.0
CONST DIST_MAX = 28.0

RENDER.SETMSAA(FALSE)
APP.OPEN(1280, 720, "moonBASIC — sphere drop (3D physics)")
APP.SETFPS(60)
CURSOR.SHOW()

PHYSICS3D.START()
PHYSICS3D.SETGRAVITY(0, -18.0, 0)
PHYSICS3D.SETSUBSTEPS(4)

; Static platform
floorDef = BODY3D.CREATE("STATIC")
floorDef.ADDBOX(PLAT_HX, PLAT_HY, PLAT_HZ)
floorBody = floorDef.COMMIT(0.0, -PLAT_HY, 0.0)

floorEnt = ENTITY.CREATECUBE(1, 1, 1)
floorEnt.SETSCALE(PLAT_HX * 2.0, PLAT_HY * 2.0, PLAT_HZ * 2.0)
floorEnt.SETPOS(0.0, -PLAT_HY, 0.0)
floorEnt.SETCOLOR(90, 95, 110, 255)
floorEnt.LINKPHYSBUFFER(floorBody.BUFFERINDEX())

; Ball Storage (typed handle arrays: name AS HANDLE(dim) — not DIM name(dim) AS …)
ballEnt AS HANDLE(MAX_BALLS)
ballBody AS HANDLE(MAX_BALLS)
DIM ballActive(MAX_BALLS)

cam = CAMERA.CREATE()
cam.SETFOV(56)

camYaw = 0.45
camPitch = 0.35
cdist = 12.0
orbitHavePrev = 0
orbitPx = 0.0
orbitPy = 0.0
lmbWasDown = 0
colorIdx = 0

WHILE NOT (INPUT.KEYDOWN(KEY_ESCAPE) OR APP.SHOULDCLOSE())
    RENDER.CLEAR(32, 38, 52)
    dt = APP.DELTA()

    ; Orbit camera
    IF INPUT.MOUSEDOWN(ORBIT_BTN) THEN
        mx = FLOAT(INPUT.MOUSEX())
        my = FLOAT(INPUT.MOUSEY())
        IF orbitHavePrev = 1 THEN
            camYaw = camYaw + (mx - orbitPx) * ORBIT_SENS
            camPitch = camPitch - (my - orbitPy) * ORBIT_SENS
        ENDIF
        orbitPx = mx
        orbitPy = my
        orbitHavePrev = 1
    ELSE
        orbitHavePrev = 0
    ENDIF
    camPitch = CLAMP(camPitch, PITCH_MIN, PITCH_MAX)
    mw = INPUT.MOUSEWHEELMOVE()
    cdist = cdist - mw * ZOOM_WHEEL
    cdist = CLAMP(cdist, DIST_MIN, DIST_MAX)
    IF INPUT.KEYDOWN(KEY_Q) THEN camYaw = camYaw - 1.1 * dt
    IF INPUT.KEYDOWN(KEY_E) THEN camYaw = camYaw + 1.1 * dt

    ; Spawn Logic
    lmbDown = INPUT.MOUSEDOWN(LEFT_BTN)
    IF (lmbDown AND NOT lmbWasDown) OR INPUT.KEYHIT(KEY_SPACE) THEN
        spawnDone = 0
        FOR i = 1 TO MAX_BALLS
            IF NOT spawnDone AND NOT ballActive(i) THEN
                pickRay = cam.MOUSERAY()
                sx = (FLOAT(RND(0, 1000)) / 1000.0 - 0.5) * 8.0
                sz = (FLOAT(RND(0, 1000)) / 1000.0 - 0.5) * 8.0
                IF pickRay.HITPLANE(0.0, 1.0, 0.0, 0.0) THEN
                    sx = pickRay.POINTX()
                    sz = pickRay.POINTZ()
                    sx = CLAMP(sx, -PLAT_HX + BALL_R, PLAT_HX - BALL_R)
                    sz = CLAMP(sz, -PLAT_HZ + BALL_R, PLAT_HZ - BALL_R)
                ENDIF
                pickRay.FREE()
                
                bdef = BODY3D.CREATE("DYNAMIC")
                bdef.ADDSPHERE(BALL_R)
                bh = bdef.COMMIT(sx, SPAWN_Y, sz)
                bh.SETBOUNCE(0.15)
                bh.SETFRICTION(0.6)
                bh.ACTIVATE()
                
                be = ENTITY.CREATESPHERE(BALL_R, SEGS)
                colorIdx = colorIdx + 1
                tcol = colorIdx * 47
                cr = 80 + tcol - INT(tcol / 175) * 175
                tcol = colorIdx * 91
                cg = 60 + tcol - INT(tcol / 195) * 195
                tcol = colorIdx * 73
                cb = 100 + tcol - INT(tcol / 155) * 155
                be.SETCOLOR(cr, cg, cb)
                
                be.LINKPHYSBUFFER(bh.BUFFERINDEX())
                ballEnt(i) = be
                ballBody(i) = bh
                ballActive(i) = 1
                spawnDone = 1
            ENDIF
        NEXT i
    ENDIF
    lmbWasDown = lmbDown

    ; Simulation
    PHYSICS3D.STEP()

    ; Cleanup Logic (assign arr(i) to locals before handle methods — statement form does not allow arr(i).METHOD())
    FOR i = 1 TO MAX_BALLS
        IF ballActive(i) THEN
            be = ballEnt(i)
            bh = ballBody(i)
            ex, ey, ez = ENTITY.GETPOS(be)
            IF ey < -2.5 OR ABS(ex) > EDGE_KILL OR ABS(ez) > EDGE_KILL THEN
                be.CLEARPHYSBUFFER()
                bh.FREE()
                be.FREE()
                ballActive(i) = 0
            ENDIF
        ENDIF
    NEXT i

    ; Rendering
    cam.SETORBIT(0.0, 0.35, 0.0, camYaw, camPitch, cdist)
    cam.BEGIN()
        Draw3D.Grid(24, 1.0)
        ENTITY.DRAWALL()
    cam.END()

    alive = 0
    FOR i = 1 TO MAX_BALLS
        IF ballActive(i) THEN alive = alive + 1
    NEXT i
    Draw.Text("LMB or SPACE spawn sphere   RMB drag orbit   wheel zoom   Q/E yaw   ESC quit", 10, 10, 17, 220, 230, 245, 255)
    Draw.Text("Active balls: " + STR(alive), 10, 32, 17, 180, 230, 160, 255)
    RENDER.FRAME()
WEND

; Cleanup
FOR i = 1 TO MAX_BALLS
    IF ballActive(i) THEN
        be = ballEnt(i)
        bh = ballBody(i)
        be.CLEARPHYSBUFFER()
        bh.FREE()
        be.FREE()
    ENDIF
NEXT i

floorEnt.CLEARPHYSBUFFER()
floorBody.FREE()
floorEnt.FREE()

PHYSICS3D.STOP()
CURSOR.SHOW()
cam.FREE()
APP.CLOSE()

