; Third-person hop: rule collisions, camera-relative walk (no forced player yaw), coyote jump, orbit camera.
; Run: moonrun examples/mario64/main_entities.mb
;
; Orbit camera (pure math, no collision): yaw/pitch/distance → spherical offset from target; camera looks at target.
; Mouse deltas: INPUT.MOUSEXSPEED / INPUT.MOUSEYSPEED (same frame as RENDER.CLEAR). Orbit only while orbit button held.
; Wheel adjusts distance (clamped). CAMERA.ORBITENTITY applies yaw/pitch/distance + look-at.

CONST TYPE_PLAYER = 1
CONST TYPE_GROUND = 2
; Which button must be held to orbit: 0 = left, 1 = right, 2 = middle (Raylib / INPUT.MOUSEDOWN).
CONST ORBIT_MOUSE_BTN = 1
; Radians per pixel (GetMouseDelta). Tune for feel.
CONST ORBIT_YAW_SENS = 0.0032
CONST ORBIT_PITCH_SENS = 0.0032
; Pitch limits (radians). ~80° above horizon max; small floor so you cannot look under the floor.
CONST PITCH_MIN = -0.12
CONST PITCH_MAX = 1.396
; Zoom: wheel scales distance; clamped.
CONST DIST_MIN = 2.5
CONST DIST_MAX = 24.0
CONST ZOOM_WHEEL = 0.9

; MSAA before OPEN (see APP.SETMSAA) — smoother grid/edges; less harsh aliasing at the horizon.
SetMSAA(4)
APP.OPEN(960, 540, "moonBASIC - entity hop (entities + collisions)")
APP.SETFPS(60)

cam = CAMERA.CREATE()
cam.SetFOV(55)

COLLISIONS(TYPE_PLAYER, TYPE_GROUND, 2, 2)

; Floor (top face slightly below Y=0 so Draw3D.Grid at Y=0 does not z-fight with this slab)
floor = ENTITY.CREATECUBE(1, 1, 1)
ENTITY.SCALE(floor, 48.0, 0.5, 48.0)
ENTITY.SETPOS(floor, 0.0, -0.27, 0.0, TRUE)
ENTITY.TYPE(floor, TYPE_GROUND)
; Floor: distinct from sky (72,92,140) so the slab reads as terrain, not empty blue.
ENTITY.COLOR(floor, 38, 48, 72, 255)

; Shared template for platforms (type + mesh); scale/color per instance
platProto = ENTITY.CREATECUBE(1, 1, 1)
ENTITY.TYPE(platProto, TYPE_GROUND)

p1 = ENTITY.COPY(platProto)
ENTITY.SCALE(p1, 4.0, 0.4, 4.0)
ENTITY.SETPOS(p1, 0.0, 1.5, 6.0, TRUE)
ENTITY.COLOR(p1, 255, 60, 200, 255)

p2 = ENTITY.COPY(platProto)
ENTITY.SCALE(p2, 2.5, 0.35, 2.5)
ENTITY.SETPOS(p2, -3.5, 2.5, 10.0, TRUE)
ENTITY.COLOR(p2, 40, 255, 230, 255)

p3 = ENTITY.COPY(platProto)
ENTITY.SCALE(p3, 2.0, 0.3, 2.0)
ENTITY.SETPOS(p3, 4.0, 3.2, 14.0, TRUE)
ENTITY.COLOR(p3, 120, 255, 80, 255)

p4 = ENTITY.COPY(platProto)
ENTITY.SCALE(p4, 3.0, 0.35, 3.0)
ENTITY.SETPOS(p4, 0.0, 4.0, 18.0, TRUE)
ENTITY.COLOR(p4, 255, 210, 60, 255)

ENTITY.FREE(platProto)

; Player root (physics sphere)
player = ENTITY.CREATESPHERE(0.5)
ENTITY.RADIUS(player, 0.45)
ENTITY.TYPE(player, TYPE_PLAYER)
ENTITY.SETPOS(player, 0.0, 1.0, 0.0, TRUE)
ENTITY.COLOR(player, 255, 95, 255, 255)

; Visual hat (child)
hat = ENTITY.CREATESPHERE(0.5, 16)
ENTITY.PARENT(hat, player)
ENTITY.SCALE(hat, 0.35, 0.35, 0.35)
ENTITY.SETPOS(hat, 0.0, 0.85, 0.0, FALSE)
ENTITY.COLOR(hat, 70, 255, 140, 255)

; Spherical orbit state: yaw, pitch, distance — CAMERA.ORBITENTITY + ENTITY.MOVECAMERARELATIVE.
camYaw = 0.0
camPitch = 0.22
cd = 7.5
moveSpd = 11.0

WHILE NOT (INPUT.KEYDOWN(KEY_ESCAPE) OR APP.SHOULDCLOSE())
    ; RENDER.CLEAR starts the frame (BeginDrawing + input poll). Read mouse speed after this.
    RENDER.CLEAR(72, 92, 140)
    dt = APP.DELTA()
    IF dt <= 0.0 THEN dt = 0.0167
    IF dt > 0.05 THEN dt = 0.05

    dx = INPUT.MOUSEXSPEED()
    dy = INPUT.MOUSEYSPEED()
    IF INPUT.MOUSEDOWN(ORBIT_MOUSE_BTN) THEN
        camYaw = camYaw + dx * ORBIT_YAW_SENS
        camPitch = camPitch - dy * ORBIT_PITCH_SENS
    ENDIF
    IF camPitch < PITCH_MIN THEN camPitch = PITCH_MIN
    IF camPitch > PITCH_MAX THEN camPitch = PITCH_MAX

    mw = INPUT.MOUSEWHEELMOVE()
    cd = cd - mw * ZOOM_WHEEL
    IF cd < DIST_MIN THEN cd = DIST_MIN
    IF cd > DIST_MAX THEN cd = DIST_MAX

    IF INPUT.KEYDOWN(KEY_Q) THEN camYaw = camYaw - 1.35 * dt
    IF INPUT.KEYDOWN(KEY_E) THEN camYaw = camYaw + 1.35 * dt

    ; Orbit with current yaw before movement so ENTITY.MOVECAMERARELATIVE matches what you see (same frame).
    CAMERA.ORBITENTITY(cam, player, camYaw, camPitch, cd)

    f = 0.0
    s = 0.0
    IF INPUT.KEYDOWN(KEY_W) THEN f = f + 1.0
    IF INPUT.KEYDOWN(KEY_S) THEN f = f - 1.0
    IF INPUT.KEYDOWN(KEY_A) THEN s = s - 1.0
    IF INPUT.KEYDOWN(KEY_D) THEN s = s + 1.0
    ENTITY.MOVECAMERARELATIVE(player, f * moveSpd * dt, s * moveSpd * dt, cam)

    ENTITY.UPDATE(dt)

    IF ENTITY.GROUNDED(player) AND INPUT.KEYHIT(KEY_SPACE) THEN
        ENTITY.ADDFORCE(player, 0.0, 10.5, 0.0)
    ENDIF

    ; Follow player after physics (position may have changed).
    CAMERA.ORBITENTITY(cam, player, camYaw, camPitch, cd)

    RENDER.Begin3D(cam)
        ENTITY.DRAWALL()
        ; Reference grid: wider spacing + fewer divisions reduces horizon moire; Y offset clears floor slab (top ~ -0.02).
        Draw3D.Grid(14, 2.0, 0.04)
        ; Wire boxes slightly above platform centers so outlines do not z-fight with solid cubes.
        Draw3D.CubeWires(0.0, 1.53, 6.0, 4.05, 0.45, 4.05, 255, 255, 255, 200)
        Draw3D.CubeWires(-3.5, 2.53, 10.0, 2.55, 0.4, 2.55, 255, 255, 255, 180)
        Draw3D.CubeWires(4.0, 3.23, 14.0, 2.05, 0.35, 2.05, 255, 255, 255, 180)
        Draw3D.CubeWires(0.0, 4.03, 18.0, 3.05, 0.4, 3.05, 255, 255, 255, 180)
    RENDER.END3D()

    Draw.Text("ENTITY hop - hold orbit btn (ORBIT_MOUSE_BTN)  wheel  Q/E  WASD  SPACE  ESC", 12, 10, 14, 245, 250, 255, 255)
    RENDER.FRAME()
WEND

CAMERA.FREE(cam)
APP.CLOSE()
