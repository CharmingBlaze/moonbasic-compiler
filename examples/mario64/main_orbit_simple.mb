; =============================================================================
;  main_orbit_simple.mb — Blitz3D-style third-person orbit + hop (teaching)
; =============================================================================
;
;  What this file is for
;    Blitz-style “immediate mode” 3D (BOX / WIRECUBE / FLAT / GRID3) + spherical
;    orbit (CAMERA.SETORBIT), walk on cam yaw, jump, LANDBOXES, ERASE ALL.
;    See docs/reference/BLITZ3D.md for the Blitz → moonBASIC map.
;
;  Read the source top → bottom in this order
;    1) CONST blocks — physics, orbit, palette, floor/grid/player mesh
;    2) Camera + state — scalars only (no extra heap for orbit deltas)
;    3) DIM platform rows — parallel arrays (required shape for LANDBOXES)
;    4) WHILE loop — input → physics → CAMERA.SETORBIT → draw → HUD
;    5) ERASE ALL — see MEMORY.md
;
;  One frame, in order (the WHILE body)
;    DT → orbit (yaw/pitch/dist) → CLAMP pitch & dist → walk (MOVESTEP* + CLAMP XZ)
;    → jump / gravity → land on boxes or floor → SetOrbit → 3D draw → 2D HUD → Frame
;
;  Next steps (same folder)
;    main_v2.mb — more comments, BOXTOPLAND loop · main_v3.mb — TYPE / DIM AS platforms
;
;  Controls
;    Q/E      yaw the orbit (keyboard)
;    R-drag   yaw + pitch (mouse)
;    wheel    zoom orbit distance
;    WASD     move on the ground plane (relative to cam yaw)
;    Space    jump (edge-triggered)
;    Esc      quit
;
;  Docs (short map)
;    Blitz3D-style map:           docs/reference/BLITZ3D.md
;    Orbit deltas (float-only):  docs/reference/GAMEHELPERS.md
;    CAMERA.SETORBIT / Orbit:     docs/reference/CAMERA.md (Orbit = SetOrbit alias)
;    3D shortcuts (BOX, WIRECUBE, FLAT, …): docs/reference/DRAW3D.md
;    ERASE ALL / FREE.ALL:        docs/MEMORY.md
;
;  Run (needs CGO + raylib)
;    moonrun examples/mario64/main_orbit_simple.mb
;
; =============================================================================

APP.OPEN(960, 540, "Blitz-style orbit hop")
APP.SETFPS(60)

; --- physics & world ---------------------------------------------------------
; --- physics & world ---------------------------------------------------------
CONST MOVE_SPEED = 10.0
CONST PLAYER_R = 0.45
CONST GRAVITY = -24.0
CONST JUMP = 9.5
CONST GROUND_SNAP_EPS = 0.02
CONST WORLD_X0 = -14.0
CONST WORLD_X1 = 14.0
CONST WORLD_Z0 = -14.0
CONST WORLD_Z1 = 18.0

; --- orbit input (GAME helpers — radians / units; no ERASE) ------------------
CONST MOUSE_SENS = 0.0048
CONST ORBIT_DEG_S = 72.0
CONST WHEEL_ZOOM = 0.85
CONST PITCH_MIN = 0.12
CONST PITCH_MAX = 1.38
CONST DIST_MIN = 3.0
CONST DIST_MAX = 22.0
; Look-at point slightly above capsule centre so the camera feels over the shoulder
CONST CAM_TARGET_YOFF = 0.15

; --- one platform (parallel DIM rows for LANDBOXES) --------------------------
CONST PLAT_N = 1

; --- palette (RGB 0–255) — tweak here to restyle the whole scene --------------
CONST C_SKY_R = 42 : CONST C_SKY_G = 78 : CONST C_SKY_B = 118
CONST C_GRASS_R = 52 : CONST C_GRASS_G = 118 : CONST C_GRASS_B = 86
CONST C_BOX_R = 255 : CONST C_BOX_G = 140 : CONST C_BOX_B = 96
CONST C_WIRE_R = 255 : CONST C_WIRE_G = 230 : CONST C_WIRE_B = 200
CONST C_BODY_R = 40 : CONST C_BODY_G = 95 : CONST C_BODY_B = 200
CONST C_HEAD_R = 255 : CONST C_HEAD_G = 210 : CONST C_HEAD_B = 120

; --- scene scale (visual) ----------------------------------------------------
CONST FLOOR_HALF = 20.0
CONST GRID_SLICES = 24
CONST GRID_STEP = 1.0
CONST BOX_WIRE_INSET = 0.05
CONST CAM_FOV = 55.0
; Player proxy (capsule + sphere) — sizes only affect drawing
CONST P_CAP_BOT = 0.42
CONST P_CAP_TOP = 0.48
CONST P_CAP_RAD = 0.38
CONST P_HEAD_RAD = 0.24
CONST P_HEAD_YOFF = 0.72

cam = CAMERA.CREATE()
cam.SetFOV(CAM_FOV)

px = 0.0
py = PLAYER_R
pz = 0.0
pvy = 0.0
ong = FALSE
camYaw = 0.0
camPitch = 0.22
camDist = 8.0

DIM plx(PLAT_N)
DIM ply(PLAT_N)
DIM plz(PLAT_N)
DIM plw(PLAT_N)
DIM plh(PLAT_N)
DIM pld(PLAT_N)
DIM pr(PLAT_N)
DIM pg(PLAT_N)
DIM pb(PLAT_N)
; Platform 0 — centre (x,y,z), half-sizes (w,h,d), RGB
plx(0) = 0.0 : ply(0) = 1.2 : plz(0) = 5.0
plw(0) = 3.0 : plh(0) = 0.35 : pld(0) = 3.0
pr(0) = C_BOX_R : pg(0) = C_BOX_G : pb(0) = C_BOX_B

WHILE NOT (INPUT.KEYDOWN(KEY_ESCAPE) OR APP.SHOULDCLOSE())
    dt = DT()

    ; ----- orbit (GAME.* deltas are floats — no ERASE) ------------------------
    camYaw = camYaw + ORBITYAWDELTA(dt, MOUSE_SENS, KEY_Q, KEY_E, ORBIT_DEG_S)
    camPitch = camPitch + ORBITPITCHDELTA(MOUSE_SENS)
    camDist = camDist + ORBITDISTDELTA(WHEEL_ZOOM)
    camPitch = CLAMP(camPitch, PITCH_MIN, PITCH_MAX)
    camDist = CLAMP(camDist, DIST_MIN, DIST_MAX)

    ; ----- walk — MOVESTEP* uses the same camYaw as CAMERA.SETORBIT below -----
    fwd = INPUT.AXIS(KEY_S, KEY_W)
    side = INPUT.AXIS(KEY_A, KEY_D)
    px = CLAMP(px + MOVESTEPX(camYaw, fwd, side, MOVE_SPEED, dt), WORLD_X0, WORLD_X1)
    pz = CLAMP(pz + MOVESTEPZ(camYaw, fwd, side, MOVE_SPEED, dt), WORLD_Z0, WORLD_Z1)

    ; ----- jump, gravity, then land (box tops first, then y=0 floor) ----------
    IF ong AND KEYHIT(KEY_SPACE) THEN pvy = JUMP
    pvy = pvy + GRAVITY * dt
    py = py + pvy * dt

    ong = FALSE
    landY = LANDBOXES(px, py, pz, pvy, PLAYER_R, plx, ply, plz, plw, plh, pld, PLAT_N)
    IF landY > 0.0 THEN
        py = landY
        pvy = 0.0
        ong = TRUE
    ENDIF
    IF NOT ong AND py - PLAYER_R <= GROUND_SNAP_EPS AND pvy <= 0.0 THEN
        py = PLAYER_R
        pvy = 0.0
        ong = TRUE
    ENDIF

    CAMERA.SETORBIT(cam, px, py + CAM_TARGET_YOFF, pz, camYaw, camPitch, camDist)

    ; ----- draw (Clear = background; Begin/End = 3D) --------------------------
    RENDER.CLEAR(C_SKY_R, C_SKY_G, C_SKY_B)
    cam.Begin()
        ; --- world (Blitz-style short names — see DRAW3D.md / BLITZ3D.md) ---
        FLAT(0.0, 0.0, 0.0, FLOOR_HALF * 2.0, FLOOR_HALF * 2.0, C_GRASS_R, C_GRASS_G, C_GRASS_B, 255)
        GRID3(GRID_SLICES, GRID_STEP)
        BOX(plx(0), ply(0), plz(0), plw(0), plh(0), pld(0), pr(0), pg(0), pb(0), 255)
        WIRECUBE(plx(0), ply(0), plz(0), plw(0) + BOX_WIRE_INSET, plh(0) + BOX_WIRE_INSET, pld(0) + BOX_WIRE_INSET, C_WIRE_R, C_WIRE_G, C_WIRE_B, 210)
        ; --- player proxy (not physics — PLAYER_R is the real collider) -------
        CAP(px, py - P_CAP_BOT, pz, px, py + P_CAP_TOP, pz, P_CAP_RAD, 10, 12, C_BODY_R, C_BODY_G, C_BODY_B, 255)
        BALL(px, py + P_HEAD_YOFF, pz, P_HEAD_RAD, C_HEAD_R, C_HEAD_G, C_HEAD_B, 255)
    cam.End()

    Draw.Text("Blitz-style orbit hop", 36, 12, 18, 250, 252, 255, 255)
    Draw.Text("Q/E · R-drag · wheel · WASD · Space · Esc", 36, 36, 14, 200, 215, 235, 255)
    Draw.Text(IIF(ong, "Ground", "Air"), 36, 58, 15, IIF(ong, 140, 255), IIF(ong, 255, 200), IIF(ong, 190, 140), 255)
    RENDER.FRAME()
WEND

ERASE ALL
APP.CLOSE()
