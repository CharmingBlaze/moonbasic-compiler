; Simple third-person hop: ground, floating blocks, orbit camera (no skybox, no entity graph).
; Run (full runtime): moonrun examples/mario64/main.mb

APP.OPEN(960, 540, "moonBASIC — simple 3D hop")
APP.SETFPS(60)
; Hide the OS cursor during play; restore before close. See docs/reference/INPUT.md (Cursor).
CURSOR.HIDE()

cam = CAMERA.CREATE()
cam.SetFOV(55)

; Player: capsule/sphere center (px, py, pz), radius pr
px = 0.0
py = 0.45
pz = 0.0
pvx = 0.0
pvz = 0.0
pvy = 0.0
pr = 0.45
ong = FALSE
camYaw = 0.0
camPitch = 0.22
cd = 7.5
moveSpd = 11.0
orbitHavePrev = FALSE
orbitPx = 0.0
orbitPy = 0.0

WHILE NOT (INPUT.KEYDOWN(KEY_ESCAPE) OR APP.SHOULDCLOSE())
    ; Begin frame before sampling mouse — raylib polls input inside BeginDrawing (first RENDER.CLEAR).
    RENDER.CLEAR(72, 92, 140)
    dt = APP.DELTA()
    IF dt > 0.05 THEN dt = 0.05

    ; Orbit: drag with RMB/LMB/MMB — screen position delta (MOUSEDELTA is often 0 on Windows with visible cursor).
    orbitGrab = INPUT.MOUSEDOWN(0) OR INPUT.MOUSEDOWN(1) OR INPUT.MOUSEDOWN(2)
    IF orbitGrab THEN
        mx = FLOAT(INPUT.MOUSEX())
        my = FLOAT(INPUT.MOUSEY())
        IF orbitHavePrev THEN
            camYaw = camYaw + (mx - orbitPx) * 0.006
            camPitch = camPitch - (my - orbitPy) * 0.006
        ENDIF
        orbitPx = mx
        orbitPy = my
        orbitHavePrev = TRUE
    ELSE
        orbitHavePrev = FALSE
    ENDIF
    mw = INPUT.MOUSEWHEELMOVE()
    cd = cd - mw * 0.9
    IF cd < 2.5 THEN cd = 2.5
    IF cd > 24.0 THEN cd = 24.0
    IF INPUT.KEYDOWN(KEY_Q) THEN camYaw = camYaw - 1.35 * dt
    IF INPUT.KEYDOWN(KEY_E) THEN camYaw = camYaw + 1.35 * dt

    fwdX = 0.0 - MATH.SIN(camYaw)
    fwdZ = 0.0 - MATH.COS(camYaw)
    rigX = MATH.COS(camYaw)
    rigZ = 0.0 - MATH.SIN(camYaw)

    f = 0.0
    s = 0.0
    IF INPUT.KEYDOWN(KEY_W) THEN f = f + 1.0
    IF INPUT.KEYDOWN(KEY_S) THEN f = f - 1.0
    IF INPUT.KEYDOWN(KEY_A) THEN s = s - 1.0
    IF INPUT.KEYDOWN(KEY_D) THEN s = s + 1.0

    px = px + (fwdX * f + rigX * s) * moveSpd * dt
    pz = pz + (fwdZ * f + rigZ * s) * moveSpd * dt

    IF px < -17.0 THEN px = -17.0
    IF px > 17.0 THEN px = 17.0
    IF pz < -17.0 THEN pz = -17.0
    IF pz > 22.0 THEN pz = 22.0

    IF ong AND INPUT.KEYDOWN(KEY_SPACE) THEN pvy = 10.5
    pvy = pvy - 26.0 * dt
    py = py + pvy * dt

    feet = py - pr
    ong = FALSE

    ; Floating platforms — landing on top surface only
    top = 1.7
    IF MATH.ABS(px - 0.0) < 2.05 + pr AND MATH.ABS(pz - 6.0) < 2.05 + pr THEN
        IF pvy <= 0.0 AND feet <= top + 0.12 AND feet >= top - 0.55 THEN
            py = top + pr
            pvy = 0.0
            ong = TRUE
        ENDIF
    ENDIF
    top = 2.675
    IF MATH.ABS(px - (-3.5)) < 1.35 + pr AND MATH.ABS(pz - 10.0) < 1.35 + pr THEN
        IF pvy <= 0.0 AND feet <= top + 0.12 AND feet >= top - 0.55 THEN
            py = top + pr
            pvy = 0.0
            ong = TRUE
        ENDIF
    ENDIF
    top = 3.35
    IF MATH.ABS(px - 4.0) < 1.05 + pr AND MATH.ABS(pz - 14.0) < 1.05 + pr THEN
        IF pvy <= 0.0 AND feet <= top + 0.12 AND feet >= top - 0.55 THEN
            py = top + pr
            pvy = 0.0
            ong = TRUE
        ENDIF
    ENDIF
    top = 4.175
    IF MATH.ABS(px - 0.0) < 1.55 + pr AND MATH.ABS(pz - 18.0) < 1.55 + pr THEN
        IF pvy <= 0.0 AND feet <= top + 0.12 AND feet >= top - 0.55 THEN
            py = top + pr
            pvy = 0.0
            ong = TRUE
        ENDIF
    ENDIF

    IF NOT ong AND feet <= 0.02 AND pvy <= 0.0 THEN
        py = pr
        pvy = 0.0
        ong = TRUE
    ENDIF

    CAMERA.SETORBIT(cam, px, py + 0.2, pz, camYaw, camPitch, cd)

    cam.Begin()
        Draw3D.Plane(0.0, 0.0, 0.0, 48.0, 48.0, 55, 78, 120, 255)
        Draw3D.Grid(24, 1.0)

        Draw3D.Cube(0.0, 1.5, 6.0, 4.0, 0.4, 4.0, 255, 60, 200, 255)
        Draw3D.CubeWires(0.0, 1.5, 6.0, 4.05, 0.45, 4.05, 255, 255, 255, 200)

        Draw3D.Cube(-3.5, 2.5, 10.0, 2.5, 0.35, 2.5, 40, 255, 230, 255)
        Draw3D.CubeWires(-3.5, 2.5, 10.0, 2.55, 0.4, 2.55, 255, 255, 255, 180)

        Draw3D.Cube(4.0, 3.2, 14.0, 2.0, 0.3, 2.0, 120, 255, 80, 255)
        Draw3D.CubeWires(4.0, 3.2, 14.0, 2.05, 0.35, 2.05, 40, 60, 40, 200)

        Draw3D.Cube(0.0, 4.0, 18.0, 3.0, 0.35, 3.0, 255, 210, 60, 255)
        Draw3D.CubeWires(0.0, 4.0, 18.0, 3.05, 0.4, 3.05, 90, 70, 20, 200)

        Draw3D.Capsule(px, py - 0.42, pz, px, py + 0.48, pz, 0.38, 10, 12, 255, 95, 255, 255)
        Draw3D.Sphere(px, py + 0.72, pz, 0.24, 70, 255, 140, 255)
    cam.End()

    Draw.Text("WASD move   R-drag orbit   wheel zoom   Q/E yaw   SPACE jump   ESC", 60, 12, 17, 245, 250, 255, 255)
    IF ong THEN
        Draw.Text("On ground", 16, 36, 16, 160, 255, 190, 255)
    ELSE
        Draw.Text("Air", 16, 36, 16, 255, 220, 130, 255)
    ENDIF
    RENDER.FRAME()
WEND

CURSOR.SHOW()
CAMERA.FREE(cam)
APP.CLOSE()
