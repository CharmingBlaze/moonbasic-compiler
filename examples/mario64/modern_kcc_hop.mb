; ==========================================
; moonBASIC 64 — Modern KCC Hop
; ==========================================
; Demonstrates the v1.0 standardized handle-based API.
; Run: moonrun examples/mario64/modern_kcc_hop.mb

APP.OPEN(1280, 720, "moonBASIC 64 (Ultimate KCC)")
APP.SETFPS(60)

PHYSICS3D.START()
PHYSICS3D.SETGRAVITY(0, -40, 0)

cam = CAMERA.CREATE()
cam.SETFOV(60)

; Player Setup
player = MODEL.CREATECAPSULE(0.4, 1.0)
player.SETPOS(0, 5, 0)
player.SETCOLOR(255, 60, 60)

; Standard: CHARACTER.CREATE(entity)
CHARACTER.CREATE(player)
player.SETSTEPHEIGHT(0.3)
player.SETSNAPDISTANCE(0.5)

; Floor
floor = MODEL.CREATEBOX(100, 2, 100)
floor.SETPOS(0, -1, 0)
floor.SETCOLOR(60, 200, 90)
floor.SETCOLLISIONGROUP(1)

; A little stair to test steps
stair = MODEL.CREATEBOX(4, 0.25, 4)
stair.SETPOS(5, 0.1, 0)
stair.SETCOLOR(200, 255, 200)
stair.SETCOLLISIONGROUP(1)

; Target for Navigation test
target = MODEL.CREATEBOX(1, 1, 1)
target.SETPOS(10, 0.5, 10)
target.SETCOLOR(255, 255, 0)
target.SETRADIUS(0.5)
target.WOBBLE(0.2, 5.0)

cam.SETORBIT(player, 12.0)
player.SETROT(0, cam.YAW(), 0)

WHILE NOT (INPUT.KEYDOWN(KEY_ESCAPE) OR APP.SHOULDCLOSE())
    mz = INPUT.AXIS(KEY_S, KEY_W)
    mx = INPUT.AXIS(KEY_A, KEY_D)

    ; WASD in camera space
    player.MOVEWITHCAMERA(cam, mz, mx, 10.0)
    player.NAVUPDATE()

    ; Handle methods for life
    IF INPUT.KEYPRESSED(KEY_SPACE) AND player.ISGROUNDED() THEN
        player.JUMP(15.0)
        player.SQUASH(0.7, 0.2)
    ENDIF

    ; Navigation Toggle (G key)
    IF INPUT.KEYPRESSED(KEY_G) THEN
        player.NAVTO(10, 10, 8.0)
    ENDIF

    ; Synchronize physics
    PHYSICS3D.UPDATE()

    cam.SETORBIT(player, 12.0)
    player.SETROT(0, cam.YAW(), 0)

    RENDER.CLEAR(100, 150, 250)
    cam.BEGIN()
        ENTITY.DRAWALL()
    cam.END()

    DRAW.TEXT("WASD: Move · R-drag orbit · Q/E yaw · wheel zoom · SPACE: Jump · G: Nav to yellow", 10, 10, 20, 255, 255, 255, 255)

    IF player.ISGROUNDED() THEN
        DRAW.TEXT("GROUNDED (player.ISGROUNDED)", 10, 40, 18, 0, 255, 0, 255)
    ELSE
        DRAW.TEXT("AIRBORNE", 10, 40, 18, 255, 0, 0, 255)
    ENDIF

    RENDER.FRAME()
WEND

APP.CLOSE()
