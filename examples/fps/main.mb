; Top-down arena: WASD move, shoot line toward mouse, moving target blocks
; Run from repo root: moonrun examples/fps/main.mb

APP.OPEN(960, 540, "moonBASIC Arena (2D)")
APP.SETFPS(60)

px = 480
py = 270
t1x = 700
t1y = 120
t2x = 200
t2y = 400
t3x = 520
t3y = 320

WHILE NOT (INPUT.KEYDOWN(KEY_ESCAPE) OR APP.SHOULDCLOSE())
    dt = APP.DELTA()
    mx = INPUT.MOUSEX()
    my = INPUT.MOUSEY()

    IF INPUT.KEYDOWN(KEY_W) THEN py = py - 260 * dt
    IF INPUT.KEYDOWN(KEY_S) THEN py = py + 260 * dt
    IF INPUT.KEYDOWN(KEY_A) THEN px = px - 260 * dt
    IF INPUT.KEYDOWN(KEY_D) THEN px = px + 260 * dt
    px = MATH.MIN(920, MATH.MAX(20, px))
    py = MATH.MIN(520, MATH.MAX(20, py))

    t1x = t1x + INT(40 * MATH.SIN(TIME.GET() * 2))
    t2y = t2y + INT(35 * MATH.COS(TIME.GET() * 1.7))

    RENDER.CLEAR(10, 12, 20)
    DRAW.RECTANGLE(t1x - 18, t1y - 18, 36, 36, 220, 90, 90, 255)
    DRAW.RECTANGLE(t2x - 18, t2y - 18, 36, 36, 90, 200, 120, 255)
    DRAW.RECTANGLE(t3x - 18, t3y - 18, 36, 36, 100, 140, 220, 255)
    DRAW.RECTANGLE(INT(px) - 10, INT(py) - 10, 20, 20, 255, 220, 100, 255)
    DRAW.RECTANGLE(mx - 2, my - 12, 4, 24, 255, 255, 255, 220)
    DRAW.RECTANGLE(mx - 12, my - 2, 24, 4, 255, 255, 255, 220)

    DRAW.TEXT("WASD move   mouse aim   ESC quit", 300, 8, 18, 200, 200, 210, 255)
    RENDER.FRAME()
WEND

APP.CLOSE()
