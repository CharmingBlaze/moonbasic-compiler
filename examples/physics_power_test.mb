; Physics API syntax check (bodies, vehicle handles) — no game loop.
; Check: moonbasic --check examples/physics_power_test.mb

PRINT("Starting physics verification")

shape = SHAPE.CREATEBOX(1, 1, 1)
bf = BODY3D.CREATE("DYNAMIC")
bf.ADDBOX(1, 1, 1)
bh = bf.COMMIT(0, 10, 0)

bh.SETLIFT(0.5)
bh.SETTHRUST(10.0)
PRINT("Aero configured via handle methods")

hero = ENTITY.CREATE()
vid = hero.CREATEVEHICLE(4)
VEHICLE.SETWHEEL(vid, 0, -1, -0.5, 1, 0.4)
VEHICLE.SETWHEEL(vid, 1, 1, -0.5, 1, 0.4)
VEHICLE.SETWHEEL(vid, 2, -1, -0.5, -1, 0.4)
VEHICLE.SETWHEEL(vid, 3, 1, -0.5, -1, 0.4)
VEHICLE.SETTUNING(vid, 20.0, 1.0, 50.0, 2.0)
PRINT("Vehicle configured")

hero.SETTHROTTLE(1.0)
hero.SETSTEER(0.5)
bh.SETVELOCITY(0, 5, 0)

mass = bh.GETMASS()
PRINT("Body mass", mass)

vel = bh.GETVELOCITY()
PRINT("Body velocity handle", vel)

PRINT("Verification complete")
