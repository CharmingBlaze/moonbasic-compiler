; MoonBASIC Jet Demo
; Aerodynamics: AERO lift/thrust/drag on a BODY3D
; W/S thrust, Arrows pitch, A/D roll, Q/E yaw, ESC quit
; Check: moonbasic --check examples/demo_jet.mb
; Run:   moonrun examples/demo_jet.mb

APP.OPEN(1280, 720, "MoonBASIC Jet Demo")
APP.SETFPS(60)

PHYSICS3D.START()
PHYSICS3D.SETGRAVITY(0, -9.81, 0)

; --- Ground ---
bf = BODY3D.CREATE("STATIC")
bf.ADDBOX(100, 0.5, 100)
ground = bf.COMMIT(0, 0, 0)

; --- Jet ---
bj = BODY3D.CREATE("DYNAMIC")
bj.ADDBOX(0.8, 0.3, 2.5)
jet = bj.COMMIT(0, 1, 0)
jet.SETDAMPING(0.02, 0.4)
jet.SETCCD(TRUE)
jet.SETGRAVITYFACTOR(1.0)

jet.SETLIFT(0.008)
jet.SETDRAG(0.003)

cam = CAMERA.CREATE()
thrust = 0.0

WHILE NOT (INPUT.KEYDOWN(KEY_ESCAPE) OR APP.SHOULDCLOSE())
    dt = APP.DELTA()

    ; Throttle
    IF INPUT.KEYDOWN(KEY_W) THEN thrust = MATH.MIN(60, thrust + 30 * dt)
    IF INPUT.KEYDOWN(KEY_S) THEN thrust = MATH.MAX(0, thrust - 40 * dt)
    jet.SETTHRUST(thrust)

    ; Pitch / Roll / Yaw
    IF INPUT.KEYDOWN(KEY_UP)   THEN jet.APPLYTORQUE(-8, 0, 0)
    IF INPUT.KEYDOWN(KEY_DOWN) THEN jet.APPLYTORQUE(8, 0, 0)
    IF INPUT.KEYDOWN(KEY_A)    THEN jet.APPLYTORQUE(0, 0, 5)
    IF INPUT.KEYDOWN(KEY_D)    THEN jet.APPLYTORQUE(0, 0, -5)
    IF INPUT.KEYDOWN(KEY_Q)    THEN jet.APPLYTORQUE(0, 3, 0)
    IF INPUT.KEYDOWN(KEY_E)    THEN jet.APPLYTORQUE(0, -3, 0)

    PHYSICS3D.STEP()

    jx, jy, jz = BODY3D.GETPOS(jet)
    cam.SETORBIT(jx, jy, jz, 0.4, 0.2, 16.0)

    vel = jet.GETVELOCITY()
    spd = MATH.SQRT(vel(1)*vel(1) + vel(2)*vel(2) + vel(3)*vel(3))

    ; --- Render ---
    RENDER.CLEAR(40, 70, 120)
    cam.BEGIN()
        DRAW3D.PLANE(0, 0, 0, 200, 200, 50, 80, 50, 255)
        DRAW3D.CUBE(jx, jy, jz, 1.6, 0.6, 5.0, 180, 180, 200, 255)
        IF thrust > 5 THEN DRAW3D.SPHERE(jx, jy, jz+2.5, 0.3, 255, 150, 50, 200)
        DRAW3D.GRID(40, 2.0)
    cam.END()

    DRAW.TEXT("W/S Thrust  Arrows Pitch  A/D Roll  Q/E Yaw", 10, 10, 20, 255, 255, 255, 255)
    DRAW.TEXT("Thrust: " + STR(INT(thrust)) + "  Speed: " + STR(INT(spd)) + "  Alt: " + STR(INT(jy)) + "m", 10, 36, 18, 255, 220, 100, 255)
    RENDER.FRAME()
WEND

jet.FREE()
ground.FREE()
PHYSICS3D.STOP()
APP.CLOSE()
