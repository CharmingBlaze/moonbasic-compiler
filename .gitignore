# Local editor config and tooling paths (machine-specific; do not commit)
.claude/
.cursor/
# Accidental path created by bad tooling (do not track)
.../

testdata/file_test_out.txt
testdata/sprite_test_texture.png
/site/
/site-ci/
examples/rpg/save.json

# Scratch Go files in module root (would duplicate package main with main_fullruntime.go)
tmp_*.go

# Python tooling (manifest_entries, local scripts)
__pycache__/
*.py[cod]

# Build artifacts
*.exe
/dist/
.check/

# Jolt MinGW static libs for Windows CGO (large; build locally — see
# third_party/jolt-go/jolt/lib/windows_amd64/README.md). Omit from git unless you
# intentionally vendor a release snapshot (then force-add if needed).
third_party/jolt-go/jolt/lib/windows_amd64/*.a

# Local JoltPhysics source checkout for building static libs (CI clones its own copy).
third_party/JoltPhysics/

# Local debug/scratch artifacts
debug_output*.txt
output.txt
moonbasic.exe~
moonrun.exe~
test_error.mb
spin_test.txt
save.json
_mattest/
examples/**/*.mbc
editors/vscode-moonbasic/vscode-moonbasic-*.vsix
