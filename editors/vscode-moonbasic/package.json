{
  "name": "vscode-moonbasic",
  "displayName": "moonBASIC",
  "description": "Syntax highlighting, snippets, LSP, check/compile/run commands, and debugger for moonBASIC (.mb / .mbc).",
  "version": "0.4.0",
  "publisher": "moonbasic",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:moonbasic",
    "onDebug:moonbasic"
  ],
  "contributes": {
    "languages": [
      {
        "id": "moonbasic",
        "aliases": ["moonBASIC", "MoonBASIC"],
        "extensions": [".mb"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "moonbasic-bytecode",
        "aliases": ["moonBASIC bytecode"],
        "extensions": [".mbc"]
      }
    ],
    "grammars": [
      {
        "language": "moonbasic",
        "scopeName": "source.moonbasic",
        "path": "./syntaxes/moonbasic.tmLanguage.json"
      },
      {
        "language": "moonbasic-bytecode",
        "scopeName": "source.moonbasic",
        "path": "./syntaxes/moonbasic.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "moonbasic",
        "path": "./snippets/moonbasic.json"
      }
    ],
    "configuration": {
      "title": "moonBASIC",
      "properties": {
        "moonbasic.languageServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the moonbasic executable. When empty, the server is started as `moonbasic` from PATH."
        },
        "moonbasic.moonrunPath": {
          "type": "string",
          "default": "",
          "description": "Path to the moonrun executable for Run and Debug. When empty, uses `moonrun` from PATH."
        },
        "moonbasic.checkOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run moonbasic --check when a .mb file is saved (in addition to LSP diagnostics)."
        }
      }
    },
    "commands": [
      {
        "command": "moonbasic.check",
        "title": "Check Current File",
        "category": "moonBASIC",
        "icon": "$(verified)"
      },
      {
        "command": "moonbasic.compile",
        "title": "Compile to .mbc",
        "category": "moonBASIC",
        "icon": "$(file-binary)"
      },
      {
        "command": "moonbasic.run",
        "title": "Run with moonrun",
        "category": "moonBASIC",
        "icon": "$(run)"
      },
      {
        "command": "moonbasic.help",
        "title": "Help at Cursor",
        "category": "moonBASIC",
        "icon": "$(question)"
      },
      {
        "command": "moonbasic.openDocs",
        "title": "Open Documentation",
        "category": "moonBASIC",
        "icon": "$(book)"
      },
      {
        "command": "moonbasic.searchApi",
        "title": "Search API",
        "category": "moonBASIC",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "moonbasic.run",
          "when": "editorLangId == moonbasic",
          "group": "moonbasic@1"
        },
        {
          "command": "moonbasic.check",
          "when": "editorLangId == moonbasic",
          "group": "moonbasic@2"
        },
        {
          "command": "moonbasic.compile",
          "when": "editorLangId == moonbasic",
          "group": "moonbasic@2"
        },
        {
          "command": "moonbasic.help",
          "when": "editorLangId == moonbasic",
          "group": "moonbasic@3"
        }
      ],
      "editor/title/run": [
        {
          "command": "moonbasic.run",
          "when": "editorLangId == moonbasic",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "moonbasic.check",
          "when": "editorLangId == moonbasic"
        },
        {
          "command": "moonbasic.compile",
          "when": "editorLangId == moonbasic"
        },
        {
          "command": "moonbasic.run",
          "when": "editorLangId == moonbasic"
        },
        {
          "command": "moonbasic.help",
          "when": "editorLangId == moonbasic"
        },
        {
          "command": "moonbasic.openDocs"
        },
        {
          "command": "moonbasic.searchApi"
        }
      ]
    },
    "keybindings": [
      {
        "command": "moonbasic.searchApi",
        "key": "ctrl+shift+space",
        "when": "editorLangId == moonbasic"
      },
      {
        "command": "moonbasic.check",
        "key": "ctrl+shift+c",
        "when": "editorLangId == moonbasic"
      },
      {
        "command": "moonbasic.run",
        "key": "ctrl+f5",
        "when": "editorLangId == moonbasic"
      },
      {
        "command": "moonbasic.help",
        "key": "alt+h",
        "when": "editorLangId == moonbasic"
      }
    ],
    "problemMatchers": [
      {
        "name": "moonbasic",
        "owner": "moonbasic",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^\\[moonBASIC\\].+ in (.+) line (\\d+) col (\\d+):$",
            "file": 1,
            "line": 2,
            "column": 3
          },
          {
            "regexp": "^  (.+)$",
            "message": 1
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "moonbasic",
        "required": ["task"],
        "properties": {
          "task": {
            "type": "string",
            "description": "moonBASIC task: check, compile, or run"
          },
          "file": {
            "type": "string",
            "description": "Source file path (defaults to ${file})"
          }
        }
      }
    ],
    "debuggers": [
      {
        "type": "moonbasic",
        "label": "moonBASIC",
        "languages": ["moonbasic"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .mb source file to debug",
                "default": "${file}"
              },
              "moonrunPath": {
                "type": "string",
                "description": "Override moonrun executable path (defaults to moonbasic.moonrunPath setting)"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "moonbasic",
            "request": "launch",
            "name": "Debug moonBASIC",
            "program": "${file}"
          }
        ]
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CharmingBlaze/moonbasic-compiler.git",
    "directory": "editors/vscode-moonbasic"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
