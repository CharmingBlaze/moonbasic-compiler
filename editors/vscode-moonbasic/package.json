{
  "name": "vscode-moonbasic",
  "displayName": "moonBASIC",
  "description": "Syntax highlighting, snippets, LSP, and debugger for moonBASIC (.mb / .mbc).",
  "version": "0.2.0",
  "publisher": "moonbasic",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "moonbasic",
        "aliases": ["moonBASIC", "MoonBASIC"],
        "extensions": [".mb"],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "moonbasic-bytecode",
        "aliases": ["moonBASIC bytecode"],
        "extensions": [".mbc"]
      }
    ],
    "grammars": [
      {
        "language": "moonbasic",
        "scopeName": "source.moonbasic",
        "path": "./syntaxes/moonbasic.tmLanguage.json"
      },
      {
        "language": "moonbasic-bytecode",
        "scopeName": "source.moonbasic",
        "path": "./syntaxes/moonbasic.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "moonbasic",
        "path": "./snippets/moonbasic.json"
      }
    ],
    "configuration": {
      "title": "moonBASIC",
      "properties": {
        "moonbasic.languageServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the moonbasic executable. When empty, the server is started as `moonbasic` from PATH."
        },
        "moonbasic.moonrunPath": {
          "type": "string",
          "default": "",
          "description": "Path to the moonrun executable for debugging. When empty, uses `moonrun` from PATH."
        }
      }
    },
    "debuggers": [
      {
        "type": "moonbasic",
        "label": "moonBASIC",
        "languages": ["moonbasic"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .mb source file to debug",
                "default": "${file}"
              },
              "moonrunPath": {
                "type": "string",
                "description": "Override moonrun executable path (defaults to moonbasic.moonrunPath setting)"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "moonbasic",
            "request": "launch",
            "name": "Debug moonBASIC",
            "program": "${file}"
          }
        ]
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CharmingBlaze/moonbasic-compiler.git",
    "directory": "editors/vscode-moonbasic"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
