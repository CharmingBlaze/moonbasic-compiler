{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "moonbasic: Check current file",
      "type": "shell",
      "command": "go",
      "args": ["run", ".", "--check", "${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$moonbasic"
    },
    {
      "label": "moonbasic: Compile current file to .mbc",
      "type": "shell",
      "command": "go",
      "args": ["run", ".", "${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$moonbasic"
    },
    {
      "label": "moonrun: Run current file",
      "type": "shell",
      "command": "go",
      "args": ["run", "-tags", "fullruntime", "./cmd/moonrun", "${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
