{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "moonbasic: Check current file",
      "type": "shell",
      "command": "moonbasic",
      "args": ["--check", "${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "moonbasic: Compile current file to .mbc",
      "type": "shell",
      "command": "moonbasic",
      "args": ["${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "moonrun: Run current file",
      "type": "shell",
      "command": "moonrun",
      "args": ["${file}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
